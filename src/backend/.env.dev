# 简化开发环境配置

ENV=development
DEBUG=True

# MySQL (暂时使用 SQLite 替代)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=healthpal

# MongoDB (暂时不使用)
MONGO_HOST=localhost
MONGO_PORT=27017

# Redis (本地已安装)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=healthpal-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# 文件上传
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# OCR (暂时不配置)
OCR_API_KEY=
OCR_API_SECRET=
OCR_PROVIDER=baidu
