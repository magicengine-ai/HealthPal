# HealthPal 环境配置

# 基础配置
ENV=development
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=healthpal
MYSQL_PASSWORD=healthpal_pass
MYSQL_DATABASE=healthpal

# MongoDB 配置
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=healthpal
MONGO_PASSWORD=healthpal_pass

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# 文件上传
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# OCR 服务（百度）
OCR_PROVIDER=baidu
OCR_API_KEY=your-baidu-ocr-api-key
OCR_API_SECRET=your-baidu-ocr-secret

# 推送服务（极光）
PUSH_PROVIDER=jiguang
