<!--pages/feedback/feedback.wxml-->
<view class="container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">反馈类型 *</text>
      <picker mode="selector" range="{{feedbackTypes}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker">{{feedbackTypes[typeIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">联系方式</text>
      <input class="input" placeholder="手机/微信（可选，方便我们联系您）" value="{{contact}}" bindinput="onContactInput"/>
    </view>

    <view class="form-item">
      <text class="label">反馈内容 *</text>
      <textarea class="textarea" placeholder="请详细描述您遇到的问题或建议" value="{{content}}" bindinput="onContentInput" maxlength="500"/>
    </view>

    <view class="form-item">
      <text class="label">上传图片</text>
      <view class="image-uploader" bindtap="chooseImage">
        <view class="upload-btn">+</view>
        <view class="upload-text">添加截图</view>
      </view>
      <view class="image-preview" wx:if="{{imageUrl}}">
        <image src="{{imageUrl}}" mode="aspectFill" bindtap="previewImage"/>
        <view class="delete-btn" bindtap="deleteImage">×</view>
      </view>
    </view>
  </view>

  <view class="tip-section">
    <text class="tip-title">💡 温馨提示</text>
    <text class="tip-text">我们会在 1-3 个工作日内处理您的反馈，请耐心等待。</text>
  </view>

  <view class="button-section">
    <button class="submit-btn" bindtap="submit">提交反馈</button>
  </view>
</view>
