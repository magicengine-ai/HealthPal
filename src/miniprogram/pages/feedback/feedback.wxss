/* pages/feedback/feedback.wxss */
.container {
  padding: 20rpx;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.form-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.input {
  font-size: 28rpx;
  padding: 15rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.textarea {
  font-size: 28rpx;
  height: 200rpx;
  padding: 15rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.picker {
  font-size: 28rpx;
  padding: 15rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  color: #666;
}

.image-uploader {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  border: 2rpx dashed #ddd;
}

.upload-btn {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-top: 20rpx;
}

.image-preview image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: #f5222d;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 50rpx;
  font-size: 32rpx;
}

.tip-section {
  background-color: #fffbe6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #fa8c16;
  margin-bottom: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.button-section {
  padding: 0 20rpx 40rpx;
}

.submit-btn {
  background-color: #1890FF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 25rpx 0;
}
