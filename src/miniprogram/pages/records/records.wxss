/* pages/records/records.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  background-color: transparent;
}

/* 分类筛选 */
.category-filter {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  white-space: nowrap;
  padding: 10rpx 0;
  margin-bottom: 20rpx;
}

.category-filter::-webkit-scrollbar {
  display: none;
}

.filter-item {
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  border: 1rpx solid #E8E8E8;
}

.filter-item.active {
  background-color: #1890FF;
  color: #ffffff;
  border-color: #1890FF;
}

/* 档案列表 */
.records-list {
  display: flex;
  flex-direction: column;
}

.record-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.record-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.record-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.record-hospital {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.record-date {
  font-size: 24rpx;
  color: #999999;
}

.record-summary {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 12rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  background-color: #E6F7FF;
  color: #1890FF;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.record-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.record-status.processing {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.record-status.completed {
  background-color: #F6FFED;
  color: #52C41A;
}

.record-status.error {
  background-color: #FFF1F0;
  color: #F5222D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 添加按钮 */
.add-button {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890FF 0%, #36CFC9 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.4);
}

.add-icon {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
}
