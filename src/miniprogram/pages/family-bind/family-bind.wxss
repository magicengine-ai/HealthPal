/* pages/family-bind/family-bind.wxss */
.container {
  padding: 20rpx;
}

.search-section {
  display: flex;
  margin-bottom: 30rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.search-btn {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #1890FF;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
}

.result-section {
  text-align: center;
  padding: 60rpx 20rpx;
}

.user-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.name {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.relation {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.bind-btn {
  background-color: #1890FF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 25rpx 0;
}
