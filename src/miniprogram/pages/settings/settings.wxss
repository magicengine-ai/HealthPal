/* pages/settings/settings.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx;
  background-color: #fafafa;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger {
  background-color: #fff5f5;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-label.danger-text {
  color: #f5222d;
}

.setting-action {
  font-size: 28rpx;
  color: #1890FF;
}

.picker {
  font-size: 28rpx;
  color: #666;
}

.setting-arrow {
  color: #ccc;
  font-size: 28rpx;
}
