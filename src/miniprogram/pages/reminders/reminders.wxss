/* pages/reminders/reminders.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890FF;
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 30rpx;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.add-text {
  font-size: 28rpx;
}

.reminder-list {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.reminder-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-left {
  flex: 1;
}

.reminder-time {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1890FF;
  margin-bottom: 8rpx;
}

.reminder-text {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #ccc;
}
