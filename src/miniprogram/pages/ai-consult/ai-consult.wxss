/* pages/ai-consult/ai-consult.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-area {
  flex: 1;
  padding: 20rpx;
}

.message-list {
  padding-bottom: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.ai {
  flex-direction: row;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #fff;
  text-align: center;
  line-height: 80rpx;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-content {
  max-width: 500rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  margin: 0 20rpx;
}

.message-content.ai {
  background-color: #fff;
  border-top-left-radius: 0;
}

.message-content.user {
  background-color: #1890FF;
  color: #fff;
  border-top-right-radius: 0;
}

.message-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.message-content.user .message-time {
  color: rgba(255,255,255,0.7);
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
}

.input-box {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  margin-left: 20rpx;
  background-color: #1890FF;
  border-radius: 50%;
  text-align: center;
  line-height: 80rpx;
}

.send-icon {
  font-size: 36rpx;
}

.quick-questions {
  background-color: #fff;
  padding: 20rpx;
  border-top: 1rpx solid #e8e8e8;
}

.quick-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
}

.quick-item {
  background-color: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 15rpx;
  margin-bottom: 15rpx;
}
