/* pages/record-detail/record-detail.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 基本信息卡片 */
.info-card {
  background: linear-gradient(135deg, #1890FF 0%, #36CFC9 100%);
  color: #ffffff;
}

.info-header {
  display: flex;
  align-items: flex-start;
}

.info-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.info-hospital {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 6rpx;
}

.info-date {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 指标列表 */
.indicators-list {
  display: flex;
  flex-direction: column;
}

.indicator-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E8E8;
}

.indicator-row:last-child {
  border-bottom: none;
}

.indicator-left {
  display: flex;
  flex-direction: column;
}

.indicator-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.indicator-unit {
  font-size: 24rpx;
  color: #999999;
}

.indicator-value {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.value-number {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.value-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.indicator-value.normal .value-number {
  color: #52C41A;
}

.indicator-value.normal .value-status {
  background-color: #F6FFED;
  color: #52C41A;
}

.indicator-value.warning .value-number {
  color: #FA8C16;
}

.indicator-value.warning .value-status {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.indicator-value.error .value-number {
  color: #F5222D;
}

.indicator-value.error .value-status {
  background-color: #FFF1F0;
  color: #F5222D;
}

/* AI 解读 */
.ai-analysis {
  background-color: #F0F5FF;
}

.ai-content {
  padding: 16rpx 0;
}

.ai-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
}

.ai-actions {
  margin-top: 20rpx;
}

.ai-action-btn {
  display: inline-block;
  padding: 12rpx 32rpx;
  background-color: #1890FF;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 原始图片 */
.original-images {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.original-image {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890FF 0%, #36CFC9 100%);
  color: #ffffff;
  border: none;
}

.action-btn.secondary {
  background-color: #ffffff;
  color: #1890FF;
  border: 2rpx solid #1890FF;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.card-action {
  font-size: 26rpx;
  color: #1890FF;
}
