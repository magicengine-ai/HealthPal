/* pages/about/about.wxss */
.container {
  padding: 40rpx 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.logo-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 60rpx 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.app-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1890FF;
  margin-bottom: 10rpx;
}

.version {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.info-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #1890FF;
}

.desc-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.desc-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 15rpx;
}

.agreement-section {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.agreement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.agreement-item:last-child {
  border-bottom: none;
}

.agreement-text {
  font-size: 28rpx;
  color: #333;
}

.agreement-arrow {
  color: #ccc;
}

.copyright {
  text-align: center;
  padding: 40rpx 0;
}

.copyright text {
  font-size: 24rpx;
  color: #999;
}
