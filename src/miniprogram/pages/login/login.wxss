/* pages/login/login.wxss */
.container {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #1890FF 0%, #36cfc9 100%);
}

.logo-section {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.login-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
}

.phone-input {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e8e8e8;
  padding-bottom: 20rpx;
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 32rpx;
  color: #333;
  margin-right: 20rpx;
}

.phone-number {
  flex: 1;
  font-size: 32rpx;
}

.code-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e8e8e8;
  padding-bottom: 20rpx;
  margin-bottom: 30rpx;
}

.code-number {
  flex: 1;
  font-size: 32rpx;
}

.send-code {
  font-size: 28rpx;
  color: #1890FF;
  padding: 10rpx 20rpx;
}

.send-code.disabled {
  color: #999;
}

.agreement {
  margin-bottom: 40rpx;
}

.agree-label {
  display: flex;
  align-items: flex-start;
}

.agree-text {
  font-size: 24rpx;
  color: #666;
}

.agree-link {
  font-size: 24rpx;
  color: #1890FF;
  text-decoration: underline;
}

.login-btn {
  background-color: #1890FF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  padding: 25rpx 0;
}

.tip-section {
  text-align: center;
  margin-top: 40rpx;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}
