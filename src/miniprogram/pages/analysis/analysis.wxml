<!--pages/analysis/analysis.wxml-->
<view class="container">
  <!-- 指标选择器 -->
  <view class="indicator-selector">
    <scroll-view scroll-x class="selector-scroll">
      <view class="selector-list">
        <view class="selector-item {{currentIndicator === 'blood-pressure' ? 'active' : ''}}" 
              bindtap="switchIndicator" data-type="blood-pressure">
          血压
        </view>
        <view class="selector-item {{currentIndicator === 'blood-sugar' ? 'active' : ''}}" 
              bindtap="switchIndicator" data-type="blood-sugar">
          血糖
        </view>
        <view class="selector-item {{currentIndicator === 'weight' ? 'active' : ''}}" 
              bindtap="switchIndicator" data-type="weight">
          体重
        </view>
        <view class="selector-item {{currentIndicator === 'heart-rate' ? 'active' : ''}}" 
              bindtap="switchIndicator" data-type="heart-rate">
          心率
        </view>
        <view class="selector-item {{currentIndicator === 'temperature' ? 'active' : ''}}" 
              bindtap="switchIndicator" data-type="temperature">
          体温
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 趋势图表 -->
  <view class="card chart-card">
    <view class="card-header">
      <text class="card-title">{{indicatorName}}趋势</text>
      <view class="time-range">
        <text class="range-item {{timeRange === 'week' ? 'active' : ''}}" 
              bindtap="switchTimeRange" data-range="week">周</text>
        <text class="range-item {{timeRange === 'month' ? 'active' : ''}}" 
              bindtap="switchTimeRange" data-range="month">月</text>
        <text class="range-item {{timeRange === 'year' ? 'active' : ''}}" 
              bindtap="switchTimeRange" data-range="year">年</text>
      </view>
    </view>
    <view class="chart-container">
      <!-- 使用 canvas 绘制折线图 -->
      <canvas type="2d" id="trendChart" class="trend-chart"></canvas>
    </view>
    <view class="chart-stats">
      <view class="stat-item">
        <text class="stat-label">平均值</text>
        <text class="stat-value">{{stats.average}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">最高值</text>
        <text class="stat-value warning">{{stats.max}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">最低值</text>
        <text class="stat-value">{{stats.min}}</text>
      </view>
    </view>
  </view>

  <!-- 健康建议 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">💡 健康建议</text>
    </view>
    <view class="suggestions-list">
      <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="id">
        <view class="suggestion-icon">{{item.icon}}</view>
        <view class="suggestion-content">
          <text class="suggestion-title">{{item.title}}</text>
          <text class="suggestion-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 异常提醒 -->
  <view class="card warning-card" wx:if="{{warnings.length > 0}}">
    <view class="card-header">
      <text class="card-title">⚠️ 需要关注</text>
    </view>
    <view class="warnings-list">
      <view class="warning-item" wx:for="{{warnings}}" wx:key="id">
        <text class="warning-text">{{item}}</text>
      </view>
    </view>
  </view>
</view>
