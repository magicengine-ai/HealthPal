/* pages/analysis/analysis.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 指标选择器 */
.indicator-selector {
  margin-bottom: 20rpx;
}

.selector-scroll {
  white-space: nowrap;
}

.selector-list {
  display: inline-flex;
  flex-direction: row;
}

.selector-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  border: 1rpx solid #E8E8E8;
}

.selector-item.active {
  background-color: #1890FF;
  color: #ffffff;
  border-color: #1890FF;
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.time-range {
  display: flex;
  flex-direction: row;
  background-color: #F5F5F5;
  border-radius: 20rpx;
  padding: 6rpx;
}

.range-item {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #666666;
  border-radius: 16rpx;
}

.range-item.active {
  background-color: #ffffff;
  color: #1890FF;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

.chart-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.trend-chart {
  width: 100%;
  height: 100%;
}

.chart-stats {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E8E8;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.stat-value.warning {
  color: #FA8C16;
}

/* 建议列表 */
.suggestions-list {
  display: flex;
  flex-direction: column;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.suggestion-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.suggestion-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.suggestion-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 警告卡片 */
.warning-card {
  background-color: #FFF7E6;
  border: 1rpx solid #FFD591;
}

.warnings-list {
  display: flex;
  flex-direction: column;
}

.warning-item {
  padding: 16rpx 0;
}

.warning-item:first-child {
  padding-top: 0;
}

.warning-item:last-child {
  padding-bottom: 0;
}

.warning-text {
  font-size: 28rpx;
  color: #FA8C16;
  line-height: 1.8;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
